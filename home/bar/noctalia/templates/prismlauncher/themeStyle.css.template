QToolTip {
    color: {{colors.on_surface.default.hex}};
    background-color: {{colors.surface_bright.default.hex | set_alpha 0.95}};
    border: 1px solid {{colors.outline.default.hex}};
    border-radius: 4px;
    padding: 4px 8px;
}

QProgressBar::chunk {
    background-color: {{colors.primary.default.hex | lighten 10}};
}