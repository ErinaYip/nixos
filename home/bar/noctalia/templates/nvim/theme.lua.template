  hl("CmpItemKindStruct", { fg = c.tertiary })
  hl("CmpItemKindProperty", { fg = c.secondary })
  hl("CmpItemKindField", { fg = c.secondary })
  hl("CmpItemKindEnum", { fg = c.tertiary })
  hl("CmpItemKindConstant", { fg = c.tertiary })
  hl("CmpItemKindKeyword", { fg = c.accent })
  hl("CmpItemKindModule", { fg = c.fg_alt })
  hl("CmpItemKindText", { fg = c.fg })
