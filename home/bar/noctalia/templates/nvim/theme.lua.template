  hl("BlinkCmpMenuSelection", { fg = c.accent_fg, bg = c.accent })
  hl("BlinkCmpLabel", { fg = c.fg })
  hl("BlinkCmpLabelMatch", { fg = c.accent, bold = true })
  hl("BlinkCmpLabelDetail", { fg = c.fg_alt })
  hl("BlinkCmpLabelDescription", { fg = c.fg_alt })
  hl("BlinkCmpLabelDeprecated", { fg = c.fg_alt, italic = true })
  hl("BlinkCmpKind", { fg = c.accent, bg = c.bg_alt })
  hl("BlinkCmpSource", { fg = c.fg_alt })
  hl("BlinkCmpGhostText", { fg = c.fg_alt })
  hl("BlinkCmpDoc", { fg = c.fg, bg = c.bg })
