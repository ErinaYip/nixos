  hl("CmpItemKindFolder", { fg = c.fg_alt })
  hl("CmpItemKindEnumMember", { fg = c.tertiary })
  hl("CmpItemKindOperator", { fg = c.fg })
  hl("CmpItemKindTypeParameter", { fg = c.tertiary })
end

return M
